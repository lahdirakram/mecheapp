# Edge Function env (local dev). Copy to supabase/functions/.env and fill in.
# .env is gitignored, never commit real keys. In prod/staging these are set with
#   `supabase secrets set NAME=value --project-ref <ref>`.
# Every Deno.env.get(...) used by the functions is listed here so nothing is untracked.

# ─── Auto-injected by the Supabase runtime (do NOT set these as secrets) ───
# Provided automatically to every Edge Function; listed here for reference only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Gemini (generate / suggest) ───
# Required secret. Without it, the functions fall back to mock results.
GEMINI_API_KEY=
# Image-capable model (try-on + refine). Override if needed.
GEMINI_MODEL=gemini-2.5-flash-image
# Text model (suggestions + refine instruction normalization). Override if needed.
GEMINI_TEXT_MODEL=gemini-2.5-flash

# ─── /generate cost caps (uncompensated looks only; paid looks bypass all of these) ───
# The daily ceiling is a EURO budget divided by the estimated per-look cost.
# Default: 20 € / 0,04 € = 500 free looks/day max.
GEN_DAILY_BUDGET_EUR=20
GEN_COST_PER_LOOK_EUR=0.04
# Optional hard override in look COUNT. If set, it wins over budget/cost above.
# GEN_DAILY_CAP=500
# Per-user hourly limit on free/ad generations (abuse guard).
GEN_USER_HOURLY_CAP=8

# ─── /suggest caps (free text endpoint) ───
# Per-user hourly limit.
SUGGEST_HOURLY_CAP=20
# Global daily backstop, all users (rolling 24h). ~20000 ≈ 2 €/day at ~0,0001 €/call.
SUGGEST_DAILY_CAP=20000

# ─── RevenueCat IAP webhook (/iap-webhook) ───
# Shared secret: set the SAME value as the webhook Authorization header in the RevenueCat dashboard.
RC_WEBHOOK_SECRET=
