# Edge Function secrets (local dev). Copy to supabase/functions/.env and fill in.
# .env is gitignored — never commit your key.
GEMINI_API_KEY=
# Image-capable Gemini model (override if needed):
GEMINI_MODEL=gemini-2.5-flash-image
# Text-only Gemini model (override if needed):
GEMINI_TEXT_MODEL=gemini-2.5-flash

# ─── Cost-safety caps for /generate (uncompensated looks only; paid looks bypass) ───
# Hard daily ceiling on free/ad generations. At ~0,02 €/look, 1000 ≈ 20 €/day max.
GEN_DAILY_CAP=1000
# Per-user hourly limit on free/ad generations (abuse guard).
GEN_USER_HOURLY_CAP=8

# ─── RevenueCat IAP webhook (/iap-webhook) ───
# Shared secret: set the SAME value as the webhook Authorization header in the RevenueCat dashboard.
RC_WEBHOOK_SECRET=