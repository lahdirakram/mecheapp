# ─── Supabase (client — safe to expose; anon key is RLS-protected) ───────────
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# ─── RevenueCat (client SDK keys, per platform) ──────────────────────────────
EXPO_PUBLIC_RC_IOS_API_KEY=
EXPO_PUBLIC_RC_ANDROID_API_KEY=

# ─── Server-only secrets — set as Supabase Edge Function secrets, NEVER in app ─
#   pnpm supabase secrets set GEMINI_API_KEY=... SUPABASE_SERVICE_ROLE_KEY=... RC_WEBHOOK_SECRET=...
GEMINI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RC_WEBHOOK_SECRET=

# Active AI try-on provider: gemini | mock
TRYON_PROVIDER=gemini
